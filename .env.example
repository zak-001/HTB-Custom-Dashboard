# Create token at app.hackthebox.com/profile/settings and paste it here.
HTB_API_TOKEN=replace_me

# Modern base. Change to https://www.hackthebox.eu/api/v4 only if your token/endpoints require legacy host.
HTB_API_BASE=https://www.hackthebox.com/api/v4

# First ID is treated as you; the rest are friends.
HTB_USER_IDS=2266673,3769,4935

# You can get user IDs from the address bar when you visit a user
